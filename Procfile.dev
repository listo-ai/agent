# Dev-environment process manifest.
#
# Launch everything with:  make dev
# (Requires overmind or hivemind — see dev/README.md.)
#
# Two agents + two Studios. Cloud on 8081, edge on 8082, Studios on
# 3001/3002 pointing at their respective agent. Ctrl-C once → all four
# shut down together.

cloud:   cargo run --bin agent -- run --config dev/cloud.yaml --http 127.0.0.1:8081
edge:    cargo run --bin agent -- run --config dev/edge.yaml  --http 127.0.0.1:8082
studio-cloud: PUBLIC_AGENT_URL=http://localhost:8081 pnpm --filter @acme/studio dev --port 3001
studio-edge:  PUBLIC_AGENT_URL=http://localhost:8082 pnpm --filter @acme/studio dev --port 3002
